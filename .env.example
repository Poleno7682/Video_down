# Telegram
BOT_TOKEN=123456789:PUT_YOUR_TOKEN_HERE
# BOT_MODE: "polling" (за NAT, без домена/SSL) или "webhook" (нужен HTTPS-домен)
BOT_MODE=polling
# Поля webhook нужны только при BOT_MODE=webhook (в polling можно оставить пустыми)
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# PostgreSQL
POSTGRES_DB=video_bot
POSTGRES_USER=video_bot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+psycopg2://video_bot:CHANGE_ME_DB_PASSWORD@postgres:5432/video_bot

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Files
DOWNLOAD_DIR=/app/downloads
COOKIE_DIR=/app/cookies
LOG_DIR=/app/logs
# Постоянная подпись под каждым видео. Меняется правкой ./caption.txt
# (файл примонтирован как volume, перечитывается при каждой отправке).
CAPTION_FILE=/app/caption.txt

# Access
# Empty = public bot. Recommended: put your Telegram ID.
ALLOWED_USERS=
ADMIN_USERS=

# Anti-spam/rate limits
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_MESSAGES=8
BAN_SECONDS=600
USER_DAILY_LIMIT=50
USER_QUEUE_LIMIT=3
GLOBAL_QUEUE_LIMIT=50

# Download/Telegram limits
DEFAULT_QUALITY=720p
MAX_FILE_MB=1900
DOWNLOAD_TIMEOUT_SECONDS=900
MAX_ACTIVE_DOWNLOADS_PER_USER=1
MAX_DOWNLOAD_DURATION_SECONDS=1800

# Cache
CACHE_TTL_HOURS=168
DELETE_LOCAL_FILE_AFTER_TELEGRAM_CACHE=true

# Рассылка администратора: режим авто-выключается через столько секунд без
# активности (таймер сбрасывается после каждой рассылки).
BROADCAST_TIMEOUT_SECONDS=300

# yt-dlp cookies
# YouTube на VPS почти всегда требует cookies залогиненного аккаунта,
# иначе будет ошибка "Sign in to confirm you're not a bot".
# Экспортируйте cookies.txt (формат Netscape) и положите в ./cookies/youtube.txt
USE_COOKIES=true
FACEBOOK_COOKIES_FILE=/app/cookies/facebook.txt
INSTAGRAM_COOKIES_FILE=/app/cookies/instagram.txt
TIKTOK_COOKIES_FILE=/app/cookies/tiktok.txt
YOUTUBE_COOKIES_FILE=/app/cookies/youtube.txt

# Nginx/container
APP_HOST=0.0.0.0
APP_PORT=8080
