# Telegram
BOT_TOKEN=123456789:PUT_YOUR_TOKEN_HERE
# BOT_MODE: "polling" (за NAT, без домена/SSL) или "webhook" (нужен HTTPS-домен)
BOT_MODE=polling
# Поля webhook нужны только при BOT_MODE=webhook (в polling можно оставить пустыми)
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# PostgreSQL
POSTGRES_DB=video_bot
POSTGRES_USER=video_bot
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+psycopg2://video_bot:CHANGE_ME_DB_PASSWORD@postgres:5432/video_bot

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Files
DOWNLOAD_DIR=/app/downloads
COOKIE_DIR=/app/cookies
LOG_DIR=/app/logs
# Постоянная подпись под каждым видео. Меняется правкой ./caption.txt
# (файл примонтирован как volume, перечитывается при каждой отправке).
CAPTION_FILE=/app/caption.txt

# Access
# Empty = public bot. Recommended: put your Telegram ID.
ALLOWED_USERS=
ADMIN_USERS=

# Anti-spam/rate limits
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_MESSAGES=8
BAN_SECONDS=600
USER_DAILY_LIMIT=50
USER_QUEUE_LIMIT=3
GLOBAL_QUEUE_LIMIT=50

# Download/Telegram limits
DEFAULT_QUALITY=720p
# MAX_FILE_MB above 50 only works when USE_LOCAL_BOT_API=true below — the
# standard cloud Bot API rejects anything over 50 MB regardless of this.
MAX_FILE_MB=1900
DOWNLOAD_TIMEOUT_SECONDS=900
MAX_ACTIVE_DOWNLOADS_PER_USER=1
MAX_DOWNLOAD_DURATION_SECONDS=1800

# Self-hosted Local Bot API server — raises the Telegram upload/download
# limit from 50 MB to 2000 MB. Get TELEGRAM_API_ID/TELEGRAM_API_HASH from
# https://my.telegram.org/apps, then also start the extra service:
#   docker compose --profile local-bot-api up -d
USE_LOCAL_BOT_API=false
LOCAL_BOT_API_URL=http://telegram-bot-api:8081
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Резервный прокси для yt-dlp (скачивание + проверка на активный эфир) —
# обходит антибот-блокировки, привязанные к IP датацентра VPS (например,
# YouTube "Sign in to confirm you're not a bot"). Пусто = без прокси.
# Пример: socks5h://user:pass@host:1080 (socks5h резолвит DNS через прокси).
# ВАЖНО: список прокси теперь удобнее вести через бота — /addproxy,
# /listproxies, /delproxy (только для админов). Если через бота добавлен
# хотя бы один прокси, этот список используется вместо YTDLP_PROXY, с
# автоматическим перебором: если прокси не сработал, бот пробует следующий.
YTDLP_PROXY=

# Отдельный резервный прокси только для rezka — пробуется последним, уже
# после прямого подключения и всего пула YTDLP_PROXY/бот-прокси выше.
# Указывает на локальный контейнер `vpn` (OpenVPN-клиент, см. vpn/README.md
# и профиль docker-compose --profile rezka-vpn). Пусто = функция выключена,
# контейнер vpn не обязателен.
REZKA_VPN_PROXY_URL=
VPN_OPENVPN_USER=
VPN_OPENVPN_PASSWORD=

# rezka.ag/hdrezka.* прячутся за антибот-проверкой Anubis (proof-of-work,
# "Проверяем, что вы не бот!") — её нельзя решить обычным HTTP-запросом,
# нужно реально выполнить JS в браузере. true = перед каждым скачиванием
# с rezka.ag поднимается headless Chromium (Playwright) и проходит проверку.
# По умолчанию выключено — это заметно тяжелее по CPU/RAM, чем остальные
# сайты, и требует `playwright install chromium` в образе (уже настроено
# в Dockerfile). false = скачивание с rezka.ag будет падать с понятной
# ошибкой "антибот-страница", остальные сайты не затронуты.
REZKA_ANTIBOT_BYPASS=false

# Вжигать субтитры (ru/en, включая автосгенерированные) в кадр видео, если
# yt-dlp их находит. По умолчанию выключено — добавляет лишний проход ffmpeg.
EMBED_SUBTITLES=false

# Cache
CACHE_TTL_HOURS=168
DELETE_LOCAL_FILE_AFTER_TELEGRAM_CACHE=true

# Рассылка администратора: режим авто-выключается через столько секунд без
# активности (таймер сбрасывается после каждой рассылки).
BROADCAST_TIMEOUT_SECONDS=300

# yt-dlp cookies
# YouTube на VPS почти всегда требует cookies залогиненного аккаунта,
# иначе будет ошибка "Sign in to confirm you're not a bot".
# Экспортируйте cookies.txt (формат Netscape) и положите в ./cookies/youtube.txt
USE_COOKIES=true
FACEBOOK_COOKIES_FILE=/app/cookies/facebook.txt
INSTAGRAM_COOKIES_FILE=/app/cookies/instagram.txt
TIKTOK_COOKIES_FILE=/app/cookies/tiktok.txt
YOUTUBE_COOKIES_FILE=/app/cookies/youtube.txt

# Nginx/container
APP_HOST=0.0.0.0
APP_PORT=8080
