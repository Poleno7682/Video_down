# Normalize line endings
* text=auto

# Shell scripts must stay LF on all platforms
*.sh text eol=lf

# Python files LF
*.py text eol=lf

# Config files LF
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.env text eol=lf
Dockerfile text eol=lf
